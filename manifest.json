{
  "manifest_version": 3,
  "name": "Loren's Text Replacer",
  "version": "2.1",
  "description": "Turn short commands into full text snippets.",
  "permissions": [
    "storage",
    "activeTab" // Ensures access to the current tab; "tabs" might be more than you need.
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "32": "icon32.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "icons": {
    "16": "icon16.png",
    "32": "icon32.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [ "<all_urls>" ],
      "js": [ "content.js" ]
    }
  ]
}
